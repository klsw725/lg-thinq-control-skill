# ──────────────────────────────────────────────
# LG ThinQ API 설정
# ──────────────────────────────────────────────
# 이 파일을 .env 로 복사한 뒤 값을 채워 사용하세요.
#   cp .env.example .env
#
# 주의: .env 파일은 절대 git에 커밋하지 마세요!

# [필수] PAT 토큰 — https://connect-pat.lgthinq.com 에서 발급
THINQ_PAT_TOKEN=

# [선택] 국가코드 (ISO 3166-1 alpha-2, 기본값: KR)
THINQ_COUNTRY=KR

# [선택] 클라이언트 ID (고유한 문자열, 미설정 시 자동 생성)
# THINQ_CLIENT_ID=my-smart-home-app

# [선택] API 리전 (KR: 한국/아시아, US: 미주, EU: 유럽/중동/아프리카, 기본값: KR)
THINQ_REGION=KR

# [선택] 기본 디바이스 ID — 조회/제어 시 DEVICE_ID 인자 생략 가능
# python thinq_client.py 실행 후 출력된 deviceId를 여기에 붙여넣기
# THINQ_DEVICE_ID=
